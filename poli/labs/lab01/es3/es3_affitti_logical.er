FERENCES IMMOBILE  (codice_catastale)<br><br>\nHAS_TELEFONO (AGENZIE_ID)  REFERENCES AGENZIE  (ID)<br><br>"},"edited":true,"sceneResetToken":1774295922396,"selectedItemId":null,"oldRenamingValue":"","renamingValue":"","showRenamingInput":false,"showDataTypeOptions":false,"showReorderingMenu":false,"showExportMenu":false},"editorData":null,"showNotesDataMenu":false}