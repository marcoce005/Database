hipMenu":false,"showExportMenu":false,"showNotes":false},"schemaDesign":{"model":{"uid":79,"erCode":"/* Entities */\nentity IMMOBILE {\n    codice_catastale (id),\n    indirizzo,\n    metri_quadri,\n    stanze (multi)\n}\nentity APPARTAMENTI {\n    piano\n}\nentity AGENZIE {\n    ID (id),\n    indirizzo,\n    telefono (multi)\n}\nentity CONTRATTO {\n    data_inizio (external),\n    data_fine,\n    prezzo,\n    rinnovabile\n}\n\n/* Relationships */\nrelationship RIGUARDANTE (\n    CONTRATTO: one..one external,\n    IMMOBILE: zero..many\n)\nrelationship STIPULA (\n    CONTRATTO: one..one,\n    AGENZIE: zero..many\n)\n\n/* Generalizations */\nIMMOBILE <= {\n    APPARTAMENTI\n} (partial, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE IMMOBILE (\n    codice_catastale INTEGER NOT NULL,\n    indirizzo INTEGER NOT NULL,\n    metri_quadri INTEGER NOT NULL,\n    piano INTEGER,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (codice_catastale)\n);\nCREATE TABLE AGENZIE (\n    ID INTEGER NOT NULL,\n    indirizzo INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE CONTRATTO (\n    IMMOBILE_codice_catastale INTEGER NOT NULL,\n    data_inizio INTEGER NOT NULL,\n    data_fine INTEGER NOT NULL,\n    prezzo INTEGER NOT NULL,\n    rinnovabile INTEGER NOT NULL,\n    AGENZIE_ID INTEGER NOT NULL,\n    PRIMARY KEY (IMMOBILE_codice_catastale, data_inizio),\n    FOREIGN KEY (IMMOBILE_codice_catastale) REFERENCES IMMOBILE (codice_catastale)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (AGENZIE_ID) REFERENCES AGENZIE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_STANZE (\n    STANZE_stanze INTEGER NOT NULL,\n    IMMOBILE_codice_catastale INTEGER NOT NULL,\n    PRIMARY KEY (STANZE_stanze, IMMOBILE_codice_catastale),\n    FOREIGN KEY (IMMOBILE_codice_catastale) REFERENCES IMMOBILE (codice_catastale)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_TELEFONO (\n    AGENZIE_ID INTEGER NOT NULL,\n    TELEFONO_telefono INTEGER NOT NULL,\n    PRIMARY KEY (AGENZIE_ID, TELEFONO_telefono),\n    FOREIGN KEY (AGENZIE_ID) REFERENCES AGENZIE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":45,"_name":"IMMOBILE","_x":230,"_y":-573,"_mag":false},{"__type":"Column","_id":48,"_name":"codice_catastale","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":45,"_tableIndex":0},{"__type":"Column","_id":49,"_name":"indirizzo","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":45,"_tableIndex":1},{"__type":"Column","_id":50,"_name":"metri_quadri","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":45,"_tableIndex":2},{"__type":"Column","_id":51,"_name":"piano","_type":"integer","_identifier":false,"_unique":false,"_nullable":true,"_tableId":45,"_tableIndex":3},{"__type":"Column","_id":52,"_name":"Type","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":45,"_tableIndex":4},{"__type":"Table","_id":53,"_name":"CONTRATTO","_x":589,"_y":-588,"_mag":false},{"__type":"Column","_id":54,"_name":"IMMOBILE_codice_catastale","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":53,"_tableIndex":0},{"__type":"ForeignKey","_id":55,"_referencingColumnId":54,"_referencedColumnId":48},{"__type":"Column","_id":57,"_name":"data_inizio","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":53,"_tableIndex":1},{"__type":"Column","_id":58,"_name":"data_fine","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":53,"_tableIndex":2},{"__type":"Column","_id":59,"_name":"prezzo","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":53,"_tableIndex":3},{"__type":"Column","_id":60,"_name":"rinnovabile","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":53,"_tableIndex":4},{"__type":"Table","_id":61,"_name":"AGEN