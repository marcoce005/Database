ARIO: zero..many,\n    ISPEZIONE: one..one external\n)\nrelationship ASSEGNATO (\n    OPERAIO: one..many,\n    PRODOTTO: zero..many\n)\n\n/* Generalizations */\nMACCHINARIO <= {\n    PRODUZIONE,\n    CONTROLLO_QUALITY\n} (total, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE OPERAIO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    cognome INTEGER NOT NULL,\n    telefono INTEGER,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE PRODOTTO (\n    barcode INTEGER NOT NULL,\n    ore_processo_produttivo INTEGER NOT NULL,\n    costo INTEGER NOT NULL,\n    PRIMARY KEY (barcode)\n);\nCREATE TABLE MACCHINARIO (\n    ID INTEGER NOT NULL,\n    marca INTEGER NOT NULL,\n    modello INTEGER NOT NULL,\n    consumo INTEGER,\n    paramentro_qualitativo INTEGER,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE ISPEZIONE (\n    OPERAIO_ID INTEGER NOT NULL,\n    MACCHINARIO_ID INTEGER NOT NULL,\n    data_ora_inizio INTEGER NOT NULL,\n    data_ora_fine INTEGER NOT NULL,\n    PRIMARY KEY (OPERAIO_ID, MACCHINARIO_ID, data_ora_inizio),\n    FOREIGN KEY (OPERAIO_ID) REFERENCES OPERAIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (MACCHINARIO_ID) REFERENCES MACCHINARIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE ASSEGNATO (\n    OPERAIO_ID INTEGER NOT NULL,\n    PRODOTTO_barcode INTEGER NOT NULL,\n    PRIMARY KEY (OPERAIO_ID, PRODOTTO_barcode),\n    FOREIGN KEY (OPERAIO_ID) REFERENCES OPERAIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (PRODOTTO_barcode) REFERENCES PRODOTTO (barcode)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_CATEGORIE (\n    PRODOTTO_barcode INTEGER NOT NULL,\n    CATEGORIE_categorie INTEGER NOT NULL,\n    PRIMARY KEY (PRODOTTO_barcode, CATEGORIE_categorie),\n    FOREIGN KEY (PRODOTTO_barcode) REFERENCES PRODOTTO (barcode)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":42,"_name":"OPERAIO","_x