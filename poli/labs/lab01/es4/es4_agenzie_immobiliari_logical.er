elefono INTEGER NOT NULL,\n    email INTEGER,\n    PRIMARY KEY (CF)\n);\nCREATE TABLE AREA_GEO (\n    city INTEGER NOT NULL,\n    n_abitanti INTEGER NOT NULL,\n    superficie INTEGER NOT NULL,\n    PRIMARY KEY (city)\n);\nCREATE TABLE AGENZIE_IMMOBILIARE (\n    ID INTEGER NOT NULL,\n    indirizzo INTEGER NOT NULL,\n    p_IVA INTEGER,\n    nome_catena INTEGER,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE MANDATO (\n    AGENTE_CF INTEGER NOT NULL,\n    AGENZIE_IMMOBILIARE_ID INTEGER NOT NULL,\n    data_inizio INTEGER NOT NULL,\n    data_fine INTEGER,\n    tipo INTEGER NOT NULL,\n    PRIMARY KEY (AGENTE_CF, AGENZIE_IMMOBILIARE_ID, data_inizio),\n    FOREIGN KEY (AGENTE_CF) REFERENCES AGENTE (CF)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (AGENZIE_IMMOBILIARE_ID) REFERENCES AGENZIE_IMMOBILIARE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE COPRE (\n    AGENTE_CF INTEGER NOT NULL,\n    AREA_GEO_city INTEGER NOT NULL,\n    PRIMARY KEY (AGENTE_CF, AREA_GEO_city),\n    FOREIGN KEY (AGENTE_CF) REFERENCES AGENTE (CF)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (AREA_GEO_city) REFERENCES AREA_GEO (city)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_COMUNI (\n    AREA_GEO_city INTEGER NOT NULL,\n    COMUNI_comuni INTEGER NOT NULL,\n    PRIMARY KEY (AREA_GEO_city, COMUNI_comuni),\n    FOREIGN KEY (AREA_GEO_city) REFERENCES AREA_GEO (city)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":47,"_name":"AGENTE","_x":-967,"_y":-18,"_mag":false},{"__type":"Column","_id":50,"_name":"CF","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":47,"_tableIndex":0},{"__type":"Column","_id":51,"_name":"nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":47,"_tableIndex":1},{"__type":"Column","_id":52,"_name":"telefono","_type":"integer","_identifier":false,"_unique