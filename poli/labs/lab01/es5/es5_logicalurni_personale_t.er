 EDIFICIO {\n    ID (id),\n    indirizzo,\n    telefoni (multi)\n}\nentity TURNO {\n    data (external),\n    ora_inizio,\n    ora_fine,\n    straordinario (optional)\n}\n\n/* Relationships */\nrelationship PRESSO (\n    EDIFICIO: zero..many,\n    TURNO: one..one\n)\nrelationship SVOLTO_DA (\n    DIPENDENTI: zero..many,\n    TURNO: one..one external\n)\n\n/* Generalizations */\nDIPENDENTI <= {\n    IMPIEGATO\n} (partial, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE DIPENDENTI (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    email INTEGER NOT NULL,\n    mansione INTEGER,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE EDIFICIO (\n    ID INTEGER NOT NULL,\n    indirizzo INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE TURNO (\n    DIPENDENTI_ID INTEGER NOT NULL,\n    data INTEGER NOT NULL,\n    ora_inizio INTEGER NOT NULL,\n    ora_fine INTEGER NOT NULL,\n    straordinario INTEGER,\n    EDIFICIO_ID INTEGER NOT NULL,\n    PRIMARY KEY (DIPENDENTI_ID, data),\n    FOREIGN KEY (DIPENDENTI_ID) REFERENCES DIPENDENTI (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (EDIFICIO_ID) REFERENCES EDIFICIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_TELEFONI (\n    EDIFICIO_ID INTEGER NOT NULL,\n    TELEFONI_telefoni INTEGER NOT NULL,\n    PRIMARY KEY (EDIFICIO_ID, TELEFONI_telefoni),\n    FOREIGN KEY (EDIFICIO_ID) REFERENCES EDIFICIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_QUALIFICHE (\n    DIPENDENTI_ID INTEGER NOT NULL,\n    QUALIFICHE_qualifiche INTEGER NOT NULL,\n    PRIMARY KEY (DIPENDENTI_ID, QUALIFICHE_qualifiche),\n    FOREIGN KEY (DIPENDENTI_ID) REFERENCES DIPENDENTI (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":39,"_name":"DIPENDENTI","_x":344,"_y":-334,"_mag":false},{"__type":"Column","_id":42,"_name":"ID","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_table