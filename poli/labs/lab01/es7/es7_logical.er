   CLIENTE: zero..many,\n    LIBRO: zero..many\n)\nrelationship SCRITTO (\n    LIBRO: one..many,\n    AUTORE: zero..many\n)\n\n/* Generalizations */\nCLIENTE <= {\n    PRIVATO,\n    NON_PRIVATO\n} (total, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE CLIENTE (\n    ID INTEGER NOT NULL,\n    telefono INTEGER,\n    nome INTEGER,\n    cognome INTEGER,\n    p_IVA INTEGER,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE COMMESSO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE LIBRO (\n    ISBN INTEGER NOT NULL,\n    titolo INTEGER NOT NULL,\n    prezzo INTEGER NOT NULL,\n    n_pagine INTEGER NOT NULL,\n    PRIMARY KEY (ISBN)\n);\nCREATE TABLE AUTORE (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    cognome INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE ACQUISTA (\n    CLIENTE_ID INTEGER NOT NULL,\n    COMMESSO_ID INTEGER NOT NULL,\n    LIBRO_ISBN INTEGER NOT NULL,\n    PRIMARY KEY (CLIENTE_ID, COMMESSO_ID, LIBRO_ISBN),\n    FOREIGN KEY (CLIENTE_ID) REFERENCES CLIENTE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (COMMESSO_ID) REFERENCES COMMESSO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (LIBRO_ISBN) REFERENCES LIBRO (ISBN)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE SCRITTO (\n    LIBRO_ISBN INTEGER NOT NULL,\n    AUTORE_ID INTEGER NOT NULL,\n    PRIMARY KEY (LIBRO_ISBN, AUTORE_ID),\n    FOREIGN KEY (LIBRO_ISBN) REFERENCES LIBRO (ISBN)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (AUTORE_ID) REFERENCES AUTORE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":36,"_name":"CLIENTE","_x":149,"_y":-197,"_mag":false},{"__type":"Column","_id":38,"_name":"ID","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":36,"_tableIndex":0},{"__type":"Column","_id":39,"_name":"telefono","_type":"integer","_identifier"