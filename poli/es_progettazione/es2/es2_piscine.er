{"_main":{"step":"erDesign","restructuringHappened":false,"draftSaved":true,"showMenu":false,"showModal":false,"containerWidth":779,"containerHeight":1056,"uid":1,"showNotesDataMenu":false},"erDesign":{"model":{"uid":78,"erCode":"/* Entities */\nentity PISCINA {\n    Nome (id),\n    Telefono,\n    Responsabile,\n    Indirizzo {\n        Via,\n        Civico,\n        CAP\n    }\n}\nentity PISCINA_CON_VASCA_ESTERNA {\n    Data_inizio,\n    Data_fine\n}\nentity INSEGNANTE {\n    CF (id),\n    Cognome,\n    Telefono (optional),\n    Qualifica (multi)\n}\nentity PERSONA {\n    CF (id),\n    Nome,\n    Indirizzo,\n    Telefono\n}\nentity CORSO {\n    Nome (external),\n    Costo,\n    n_min_partecipanti,\n    n_max_partecipanti\n}\nentity TEMPO {\n    Giorno_settimana (id)\n}\nentity TEMPO2 {\n    Data_inizio (id)\n}\nentity INGRESSO_SINGOLO {\n    Data_ultimo_ingresso\n}\nentity ISCRITTO_CORSI {\n    Certificato_medico {\n        Medico,\n        Data\n    },\n    Data_nascita\n}\n\n/* Relationships */\nrelationship PRESSO (\n    PISCINA: zero..many,\n    CORSO: one..one external\n)\nrelationship LEZIONE (\n    CORSO: zero..many,\n    TEMPO: one..many\n) {\n    Ora\n}\nrelationship LAVORA (\n    INSEGNANTE: zero..many,\n    PISCINA: zero..many,\n    TEMPO2: zero..many\n) {\n    Data_fine (optional)\n}\nrelationship FREQUENTA (\n    CORSO: zero..many,\n    ISCRITTO_CORSI: one..many\n)\nrelationship ULTIMO_INGRESSO (\n    PISCINA: zero..many,\n    INGRESSO_SINGOLO: one..one\n)\n\n/* Generalizations */\nPISCINA <= {\n    PISCINA_CON_VASCA_ESTERNA\n} (partial, exclusive)\nPERSONA <= {\n    INGRESSO_SINGOLO,\n    ISCRITTO_CORSI\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Entity","_id":1,"_name":"PISCINA","_x":-501,"_y":-399,"_mag":false},{"__type":"Attribute","_id":2,"_name":"Nome","_identifier":true,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":1,"_x":-144,"_y":0},{"__type":"Attribute","_id":4,"_name":"Telefono","_identifier":false,"_externalI