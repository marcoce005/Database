TypeBRelationshipMenu":false,"showOneToOneTypeCRelationshipMenu":false,"showExportMenu":false,"showNotes":false},"schemaDesign":{"model":{"uid":181,"erCode":"/* Entities */\nentity PISCINA {\n    Nome (id),\n    Telefono,\n    Responsabile,\n    Indirizzo {\n        Via,\n        Civico,\n        CAP\n    }\n}\nentity PISCINA_CON_VASCA_ESTERNA {\n    Data_inizio,\n    Data_fine\n}\nentity INSEGNANTE {\n    CF (id),\n    Cognome,\n    Telefono (optional),\n    Qualifica (multi)\n}\nentity PERSONA {\n    CF (id),\n    Nome,\n    Indirizzo,\n    Telefono\n}\nentity CORSO {\n    Nome (external),\n    Costo,\n    n_min_partecipanti,\n    n_max_partecipanti\n}\nentity TEMPO {\n    Giorno_settimana (id)\n}\nentity TEMPO2 {\n    Data_inizio (id)\n}\nentity INGRESSO_SINGOLO {\n    Data_ultimo_ingresso\n}\nentity ISCRITTO_CORSI {\n    Certificato_medico {\n        Medico,\n        Data\n    },\n    Data_nascita\n}\n\n/* Relationships */\nrelationship PRESSO (\n    PISCINA: zero..many,\n    CORSO: one..one external\n)\nrelationship LEZIONE (\n    CORSO: zero..many,\n    TEMPO: one..many\n) {\n    Ora\n}\nrelationship LAVORA (\n    INSEGNANTE: zero..many,\n    PISCINA: zero..many,\n    TEMPO2: zero..many\n) {\n    Data_fine (optional)\n}\nrelationship FREQUENTA (\n    CORSO: zero..many,\n    ISCRITTO_CORSI: one..many\n)\nrelationship ULTIMO_INGRESSO (\n    PISCINA: zero..many,\n    INGRESSO_SINGOLO: one..one\n)\n\n/* Generalizations */\nPISCINA <= {\n    PISCINA_CON_VASCA_ESTERNA\n} (partial, exclusive)\nPERSONA <= {\n    INGRESSO_SINGOLO,\n    ISCRITTO_CORSI\n} (total, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE INSEGNANTE (\n    CF INTEGER NOT NULL,\n    Cognome INTEGER NOT NULL,\n    Telefono INTEGER,\n    PRIMARY KEY (CF)\n);\nCREATE TABLE PISCINA (\n    Nome INTEGER NOT NULL,\n    Telefono INTEGER NOT NULL,\n    Responsabile INTEGER NOT NULL,\n    Data_inizio INTEGER,\n    Data_fine INTEGER,\n    Type INTEGER NOT NULL,\n    Indirizzo_Via INTEGER NOT NULL,\n    Indirizzo_Civico INTEGER NOT NULL,\n    Indirizzo_CAP INTEGER NOT NULL,\n    PRIMARY KEY (Nome)\n);\nCREATE TABLE TEMPO (\n    Giorno_settimana INTEGER NOT NULL,\n    PRIMARY KEY (Giorno_settimana)\n);\nCREATE TABLE TEMPO2 (\n    Data_inizio INTEGER NOT NULL,\n    PRIMARY KEY (Data_inizio)\n);\nCREATE TABLE ISCRITTO_CORSI (\n    CF INTEGER NOT NULL,\n    Data_nascita INTEGER NOT NULL,\n    Nome INTEGER NOT NULL,\n    Indirizzo INTEGER NOT NULL,\n    Telefono INTEGER NOT NULL,\n    Certificato_medico_Medico INTEGER NOT NULL,\n    Certificato_medico_Data INTEGER NOT NULL,\n    PRIMARY KEY (CF)\n);\nCREATE TABLE INGRESSO_SINGOLO (\n    CF INTEGER NOT NULL,\n    Data_ultimo_ingresso INTEGER NOT NULL,\n    Nome INTEGER NOT NULL,\n    Indirizzo INTEGER NOT NULL,\n    Telefono INTEGER NOT NULL,\n    PISCINA_Nome INTEGER NOT NULL,\n    PRIMARY KEY (CF),\n    FOREIGN KEY (PISCINA_Nome) REFERENCES PISCINA (Nome)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE CORSO (\n    PISCINA_Nome INTEGER NOT NULL,\n    Nome INTEGER NOT NULL,\n    Costo INTEGER NOT NULL,\n    n_min_partecipanti INTEGER NOT NULL,\n    n_max_partecipanti INTEGER NOT NULL,\n    PRIMARY KEY (PISCINA_Nome, Nome),\n    FOREIGN KEY (PISCINA_Nome) REFERENCES PISCINA (Nome)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE LEZIONE (\n    TEMPO_Giorno_settimana INTEGER NOT NULL,\n    CORSO_PISCINA_Nome INTEGER NOT NULL,\n    CORSO_Nome INTEGER NOT NULL,\n    Ora INTEGER NOT NULL,\n    PRIMARY KEY (TEMPO_Giorno_settimana, CORSO_PISCINA_Nome, CORSO_Nome),\n    FOREIGN KEY (TEMPO_Giorno_settimana) REFERENCES TEMPO (Giorno_settimana)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (CORSO_PISCINA_Nome, CORSO_Nome) REFERENCES CORSO (PISCINA_Nome, Nome)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE LAVORA (\n    INSEGNANTE_CF INTEGER NOT NULL,\n    PISCINA_Nome INTEGER NOT NULL,\n    TEMPO2_Data_inizio INTEGER NOT NULL,\n    Data_fine INTEGER,\n    PRIMARY KEY (INSEGNANTE_CF, PISCINA_Nome, TEMPO2_Data_inizio),\n    FOREIGN KEY (INSEGNANTE_CF) REFERENCES INSEGNANTE (CF)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (PISCINA_Nome) REFERENCES PISCINA (Nome)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (TEMPO2_Data_inizio) REFERENCES TEMPO2 (Data_inizio)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE FREQUENTA (\n    ISCRITTO_CORSI_CF INTEGER NOT NULL,\n    CORSO_PISCINA_Nome INTEGER NOT NULL,\n    CORSO_Nome INTEGER NOT NULL,\n    PRIMARY KEY (ISCRITTO_CORSI_CF, CORSO_PISCINA_Nome, CORSO_Nome),\n    FOREIGN KEY (ISCRITTO_CORSI_CF) REFERENCES ISCRITTO_CORSI (CF)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (CORSO_PISCINA_Nome, CORSO_Nome) REFERENCES CORSO (PISCINA_Nome, Nome)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_QUALIFICA (\n    QUALIFICA_Qualifica INTEGER NOT NULL,\n    INSEGNANTE_CF INTEGER NOT NULL,\n    PRIMARY KEY (QUALIFICA_Qualifica, INSEGNANTE_CF),\n    FOREIGN KEY (INSEGNANTE_CF) REFERENCES INSEGNANTE (CF)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":102,"_name":"INSEGNANTE","_x":-997,"_y":-515,"_mag":false},{"__type":"Column","_id":105,"_name":"CF","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":102,"_tableIndex":0},{"__type":"Column","_id":106,"_name":"Cognome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":102,"_tableIndex":1},{"__type":"Column","_id":107,"_name":"Telefono","_type":"integer","_identifier":false,"_unique":false,"_nullable":true,"_tableId":102,"_tableIndex":2},{"__type":"Table","_id":108,"_name":"PISCINA","_x":-392,"_y":-486,"_mag":false},{"__type":"Column","_id":112,"_name":"Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":108,"_tableIndex":0},{"__type":"Column","_id":113,"_name":"Telefono","_type":"integer","_