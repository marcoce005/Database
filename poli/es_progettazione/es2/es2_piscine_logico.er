eIndex":0},"154":{"__type":"ForeignKey","_id":154,"_referencingColumnId":153,"_referencedColumnId":123},"155":{"__type":"Column","_id":155,"_name":"CORSO_PISCINA_Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":1},"156":{"__type":"ForeignKey","_id":156,"_referencingColumnId":155,"_referencedColumnId":144},"157":{"__type":"Column","_id":157,"_name":"CORSO_Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":2},"158":{"__type":"ForeignKey","_id":158,"_referencingColumnId":157,"_referencedColumnId":148},"159":{"__type":"Column","_id":159,"_name":"Ora","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":152,"_tableIndex":3},"160":{"__type":"Table","_id":160,"_name":"LAVORA","_x":-699,"_y":-365,"_mag":false},"161":{"__type":"Column","_id":161,"_name":"INSEGNANTE_CF","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":160,"_tableIndex":0},"162":{"__type":"ForeignKey","_id":162,"_referencingColumnId":161,"_referencedColumnId":105},"163":{"__type":"Column","_id":163,"_name":"PISCINA_Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":160,"_tableIndex":1},"164":{"__type":"ForeignKey","_id":164,"_referencingColumnId":163,"_referencedColumnId":112},"165":{"__type":"Column","_id":165,"_name":"TEMPO2_Data_inizio","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":160,"_tableIndex":2},"166":{"__type":"ForeignKey","_id":166,"_referencingColumnId":165,"_referencedColumnId":126},"167":{"__type":"Column","_id":167,"_name":"Data_fine","_type":"integer","_identifier":false,"_unique":false,"_nullable":true,"_tableId":160,"_tableIndex":3},"168":{"__type":"Table","_id":168,"_name":"FREQUENTA","_x":835,"_y":-561,"_mag":false},"169":{"__type":"Column","_id":169,"_name":"ISCRITTO_CORSI_CF","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":168,"_tableIndex":0},"170":{"__type":"ForeignKey","_id":170,"_referencingColumnId":169,"_referencedColumnId":136},"171":{"__type":"Column","_id":171,"_name":"CORSO_PISCINA_Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":168,"_tableIndex":1},"172":{"__type":"ForeignKey","_id":172,"_referencingColumnId":171,"_referencedColumnId":144},"173":{"__type":"Column","_id":173,"_name":"CORSO_Nome","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":168,"_tableIndex":2},"174":{"__type":"ForeignKey","_id":174,"_referencingColumnId":173,"_referencedColumnId":148},"175":{"__type":"Column","_id":175,"_name":"PISCINA_Nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":127,"_tableIndex":5},"176":{"__type":"ForeignKey","_id":176,"_referencingColumnId":175,"_referencedColumnId":112},"177":{"__type":"Table","_id":177,"_name":"HAS_QUALIFICA","_x":-1301,"_y":-550,"_mag":false},"178":{"__type":"Column","_id":178,"_name":"QUALIFICA_Qualifica","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":177,"_tableIndex":0},"179":{"__type":"Column","_id":179,"_name":"INSEGNANTE_CF","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":177,"_tableIndex":1},"180":{"__type":"ForeignKey","_id":180,"_referencingColumnId":179,"_referencedColumnId":105}},"sqlLinearCode":"<h3>Relational logical schema</h3>INSEGNANTE (<u  style=\"text-decoration: underline;\">CF</u>, Cognome, Telefono*)<br><br>\nPISCINA (<u  style=\"text-decoration: underline;\">Nome</u>, Telefono, Responsabile, Data_inizio*, Data_fine*, Type, Indirizzo_Via, Indirizzo_Civico, Indirizzo_CAP)<br><br>\nTEMPO (<u  style=\"text-decoration: underline;\">Giorno_settimana</u>)<br><br>\nTEMPO2 (<u  style=\"text-decoration: underline;\">Data_inizio</u>)<br><br>\nISCRITTO_CORSI (<u  style=\"text-decoration: underline;\">CF</u>, Data_nascita, Nome, Indirizzo, Telefono, Certificato_medico_Medico, Certificato_medico_Data)<br><br>\nINGRESSO_SINGOLO (<u  style=\"text-decoration: underline;\">CF</u>, Data_ultimo_ingresso, Nome, Indirizzo, Telefono, PISCINA_Nome)<br><br>\nCORSO (<u  style=\"text-decoration: underline;\">PISCINA_Nome</u>, <u  style=\"text-decoration: underline;\">Nome</u>, Costo, n_min_partecipanti, n_max_partecipanti)<br><br>\nLEZIONE (<u  style=\"text-decoration: underline;\">TEMPO_Giorno_settimana</u>, <u  style=\"text-decoration: underline;\">CORSO_PISCINA_Nome</u>, <u  style=\"text-decoration: underline;\">CORSO_Nome</u>, Ora)<br><br>\nLAVORA (<u  style=\"text-decoration: underline;\">INSEGNANTE_CF</u>, <u  style=\"text-decoration: underline;\">PISCINA_Nome</u>, <u  style=\"text-decoration: underline;\">TEMPO2_Data_inizio</u>, Data_fine*)<br><br>\nFREQUENTA (<u  style=\"text-decoration: underline;\">ISCRITTO_CORSI_CF</u>, <u  style=\"text-decoration: underline;\">CORSO_PISCINA_Nome</u>, <u  style=\"text-decoration: underline;\">CORSO_Nome</u>)<br><br>\nHAS_QUALIFICA (<u  style=\"text-decoration: underline;\">QUALIFICA_Qualifica</u>, <u  style=\"text-decoration: underline;\">INSEGNANTE_CF</u>)<br><br>\n\n<br><h3>Referential integrity constraints</h3>\n\n\n\n\nINGRESSO_SINGOLO (PISCINA_Nome)  REFERENCES PISCINA  (Nome)<br><br>\nCORSO (PISCINA_Nome)  REFERENCES PISCINA  (Nome)<br><br>\nLEZIONE (TEMPO_Giorno_settimana)  REFERENCES TEMPO  (Giorno_settimana)<br><br>LEZIONE (CORSO_PISCINA_Nome, CORSO_Nome)  REFERENCES CORSO  (PISCINA_Nome, Nome)<br><br>\nLAVORA (INSEGNANTE_CF)  REFERENCES INSEGNANTE  (CF)<br><br>LAVORA (PISCINA_Nome)  REFERENCES PISCINA  (Nome)<br><br>LAVORA (TEMPO2_Data_inizio)  REFERENCES TEMPO2  (Data_inizio)<br><br>\nFREQUENTA (ISCRITTO_CORSI_CF)  REFERENCES ISCRITTO_CORSI  (CF)<br><br>FREQUENTA (CORSO_PISCINA_Nome, CORSO_Nome)  REFERENCES CORSO  (PISCINA_Nome, Nome)<br><br>\nHAS_QUALIFICA (INSEGNANTE_CF)  REFERENCES INSEGNANTE  (CF)<br><br>"},"edited":true,"sceneResetToken":1773677112153,"selectedItemId":null,"oldRenamingValue":"","renamingValue":"","showRenamingInput":false,"showDataTypeOptions":false,"showReorderingMenu":false,"showExportMenu":false},"editorData":"<p>Esercizio 2 – Gestione piscine comunali</p><p>diSi vuoleTorino,•••••rappresentare una base dati contenente le informazioni relative alle piscine gestite del comune</p><p>tenendo conto delle seguenti informazioni:</p><p>Le piscine sono identificate univocamente attraverso il nome (ad esempio Vigone, Comunale,</p><p>Trecate, ecc). Per ciascuna sono inoltre noti l'indirizzo, un numero di telefono, ed il nome di un</p><p>responsabile. Nel caso la piscina disponga anche di una vasca all'aperto, la base dati contiene</p><p>l'informazione di quando tale vasca è utilizzabile (ad esempio da Marzo a Settembre, da Luglio ad</p><p>Agosto, ecc.)</p><p>Presso le piscine sono organizzati dei corsi; lo stesso tipo di corso può essere svolto presso piscine</p><p>diverse, eventualmente con modalità differenti. Ciascun corso è pertanto identificato dal nome</p><p>dell'attività svolta, quali Aerobica, Acquagym, Corso di Sincronizzato o corso per Gestanti, e dal</p><p>nome della Piscina presso cui tale corso si svolge. Per ciascun corso, svolto presso una certa</p><p>piscina, è noto il costo, il numero massimo e minimo di partecipanti, in quali giorni della settimana</p><p>si svolge ed a che ora. Si ipotizzi che presso ciascuna piscina ogni corso sia svolto una sola volta</p><p>al giorno, ma più volte durante la settimana.</p><p>Il corpo insegnante lavora a rotazione presso le varie piscine. Per ciascun insegnante è noto il</p><p>codice fiscale, che lo identifica, un nome, il numero di cellulare, se disponibile, e l'elenco delle</p><p>qualifiche dell'insegnante (ad esempio istruttore di sub, istruttore di aerobica, ecc.). All'interno</p><p>della base dati si vuole tener traccia di tutti gli intervalli di tempo in cui un insegnante ha lavorato</p><p>presso ciascuna piscina. Non si escluda che lo stesso insegnante possa aver lavorato presso una</p><p>stessa piscina in intervalli di tempo diversi.</p><p>Le piscine possono essere frequentate o da persone che sono iscritte ai corsi, o secondo la modalità</p><p>ad “ingresso singolo” per svolgere nuoto libero (si noti che sono registrate per l'ingresso singolo</p><p>solo le persone che non hanno mai frequentato corsi). Tutte le persone che accedono alle piscine</p><p>comunali sono identificate attraverso il loro codice fiscale ed inoltre sono noti il nome, un indirizzo</p><p>ed un numero di telefono.</p><p>Le persone che sono iscritte ai corsi devono presentare un certificato medico. Pertanto, nel caso la</p><p>persona sia iscritta ad un corso, il database contiene l'informazione del medico che ha redatto il</p><p>certificato, la data in cui la persona ha presentato il certificato, l'età della persona, e l'elenco dei</p><p>corsi a cui è iscritta. Per le persone che hanno fatto solo ingressi sono noti solo la data in cui è stato</p><p>effettuato l'ultimo ingresso e presso quale piscina.</p><p>a)b)Descrivere con un diagramma ER lo schema concettuale di una base di dati per tale applicazione.</p><p>Costruire uno schema logico relazionale normalizzato per la stessa base di dati.</p>","showNotesDataMenu":false}