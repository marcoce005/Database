{"_main":{"step":"erDesign","restructuringHappened":false,"draftSaved":true,"showMenu":false,"showModal":false,"containerWidth":500,"containerHeight":580,"uid":1,"showNotesDataMenu":false},"erDesign":{"model":{"uid":88,"erCode":"/* Entities */\nentity CLIENTE {\n    ID (id),\n    nome,\n    cognome,\n    indirizzo,\n    telefono\n}\nentity BUSINESS {\n    ragione_sociale\n}\nentity OPERATORE {\n    MAT (id),\n    nome,\n    congome,\n    telefono\n}\nentity CONTRATTO {\n    ID (id),\n    indirizzo,\n    data_inizio_fornitura (optional),\n    data_stipulazione,\n    kWh_max\n}\nentity PRIVATO\nentity CONTRATTO_BUSINESS {\n    tempo_risposta\n}\nentity CONTATORI {\n    ID (id),\n    modello,\n    kWh_max,\n    data_installazione\n}\nentity LETTURA {\n    data (external),\n    kWh,\n    ora\n}\nentity BOLLETTA {\n    numero (external),\n    anno (external),\n    periodo,\n    data_pagamento,\n    data_emissione,\n    costo,\n    tot_kWh\n}\nentity FASCIA_ORARIA {\n    ID (id),\n    ora_inizio,\n    ora_fine,\n    prezzo\n}\nentity AREE_GEO {\n    ID (id),\n    cities (multi)\n}\nentity TEMPO {\n    data_inizio (id)\n}\n\n/* Relationships */\nrelationship INTESTATARI (\n    CLIENTE: zero..many,\n    CONTRATTO: one..many\n)\nrelationship INTESTATARI2 (\n    BUSINESS: zero..many,\n    CONTRATTO_BUSINESS: one..many\n)\nrelationship ASSOCIATO (\n    CONTRATTO: one..one,\n    CONTATORI: one..one\n)\nrelationship PER (\n    CONTATORI: zero..many,\n    LETTURA: one..one external\n)\nrelationship FATTA_DA (\n    OPERATORE: zero..many,\n    LETTURA: one..one\n)\nrelationship APPARTIENE (\n    BOLLETTA: one..one external,\n    CONTRATTO: zero..many\n)\nrelationship CORRENTE_EROGATA (\n    BOLLETTA: one..many,\n    FASCIA_ORARIA: zero..many\n) {\n    kWh\n}\nrelationship LAVORA (\n    OPERATORE: zero..many,\n    AREE_GEO: zero..many,\n    TEMPO: one..many\n) {\n    data_fine (optional)\n}\n\n/* Generalizations */\nCLIENTE <= {\n    BUSINESS,\n    PRIVATO\n} (total, exclusive)\nCON