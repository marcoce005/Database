{"_main":{"step":"erDesign","restructuringHappened":false,"draftSaved":true,"showMenu":false,"showModal":false,"containerWidth":500,"containerHeight":580,"uid":1},"erDesign":{"model":{"uid":90,"erCode":"/* Entities */\nentity IMPIANTO {\n    ID (id),\n    nome,\n    capienza_max,\n    indirizzo {\n        via,\n        n_civico,\n        CAP\n    }\n}\nentity MEMBRO_PERSONALE {\n    nome,\n    cognome,\n    data_assunzione,\n    ID (id)\n}\nentity MANUTENTORE\nentity ISTRUTTORE {\n    specializzazioni (multi)\n}\nentity VIDEO_CORSO {\n    ID (id),\n    nome,\n    durata\n}\nentity INTERVENTO {\n    data_ora (external)\n}\nentity PRODOTTO {\n    ID (id),\n    nome,\n    costo_unitario,\n    marchio\n}\nentity RICAMBI {\n    modello,\n    certificazioni (multi)\n}\nentity CONSUMABILE {\n    scadenza (optional)\n}\nentity TEMPO {\n    data_inizio (id)\n}\nentity SOCIO {\n    ID (id),\n    nome,\n    cognome,\n    telefono\n}\nentity ABBONAMENTO {\n    ID (external),\n    data_inizio,\n    data_fine,\n    costo\n}\nentity SESSIONE {\n    data_ora_inizio (external),\n    data_ora_fine\n}\n\n/* Relationships */\nrelationship ELENCO (\n    ISTRUTTORE: zero..many,\n    VIDEO_CORSO: one..many\n)\nrelationship SVOLTO_IN (\n    INTERVENTO: one..one,\n    IMPIANTO: zero..many\n)\nrelationship SVOLTO_DA (\n    INTERVENTO: one..one external,\n    MANUTENTORE: zero..many\n)\nrelationship PRODOTTI_USATI (\n    PRODOTTO: zero..many,\n    INTERVENTO: zero..many\n) {\n    qty\n}\nrelationship LAVORA (\n    ISTRUTTORE: zero..many,\n    IMPIANTO: zero..many,\n    TEMPO: one..many\n) {\n    mansione,\n    data_fine\n}\nrelationship PER (\n    IMPIANTO: zero..many,\n    ABBONAMENTO: one..one external\n)\nrelationship SOTTOSCRIVE (\n    ABBONAMENTO: one..one,\n    SOCIO: zero..many\n)\nrelationship VISUALIZZA (\n    SOCIO: zero..many,\n    SESSIONE: one..one external\n)\nrelationship GUARDA (\n    SESSIONE: one..one,\n    VIDEO_CORSO: zero..many\n)\n\n/* Generalizations */\nMEMBRO_PERSONAL