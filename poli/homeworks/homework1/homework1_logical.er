SONALE {\n    nome,\n    cognome,\n    data_assunzione,\n    ID (id)\n}\nentity MANUTENTORE\nentity ISTRUTTORE {\n    specializzazioni (multi)\n}\nentity VIDEO_CORSO {\n    ID (id),\n    nome,\n    durata\n}\nentity INTERVENTO {\n    data_ora (external)\n}\nentity PRODOTTO {\n    ID (id),\n    nome,\n    costo_unitario,\n    marchio\n}\nentity RICAMBI {\n    modello,\n    certificazioni (multi)\n}\nentity CONSUMABILE {\n    scadenza (optional)\n}\nentity TEMPO {\n    data_inizio (id)\n}\nentity SOCIO {\n    ID (id),\n    nome,\n    cognome,\n    telefono\n}\nentity ABBONAMENTO {\n    ID (external),\n    data_inizio,\n    data_fine,\n    costo\n}\nentity SESSIONE {\n    data_ora_inizio (external),\n    data_ora_fine\n}\n\n/* Relationships */\nrelationship ELENCO (\n    ISTRUTTORE: zero..many,\n    VIDEO_CORSO: one..many\n)\nrelationship SVOLTO_IN (\n    INTERVENTO: one..one,\n    IMPIANTO: zero..many\n)\nrelationship SVOLTO_DA (\n    INTERVENTO: one..one external,\n    MANUTENTORE: zero..many\n)\nrelationship PRODOTTI_USATI (\n    PRODOTTO: zero..many,\n    INTERVENTO: zero..many\n) {\n    qty\n}\nrelationship LAVORA (\n    ISTRUTTORE: zero..many,\n    IMPIANTO: zero..many,\n    TEMPO: one..many\n) {\n    mansione,\n    data_fine\n}\nrelationship PER (\n    IMPIANTO: zero..many,\n    ABBONAMENTO: one..one external\n)\nrelationship SOTTOSCRIVE (\n    ABBONAMENTO: one..one,\n    SOCIO: zero..many\n)\nrelationship VISUALIZZA (\n    SOCIO: zero..many,\n    SESSIONE: one..one external\n)\nrelationship GUARDA (\n    SESSIONE: one..one,\n    VIDEO_CORSO: zero..many\n)\n\n/* Generalizations */\nMEMBRO_PERSONALE <= {\n    ISTRUTTORE,\n    MANUTENTORE\n} (partial, exclusive)\nPRODOTTO <= {\n    RICAMBI,\n    CONSUMABILE\n} (total, exclusive)","sqlCode":"/* Tables */\nCREATE TABLE IMPIANTO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    capienza_max INTEGER NOT NULL,\n    indirizzo_via INTEGER NOT NULL,\n    indirizzo_n_civico INTEGER NOT NULL,\n    indirizzo_CAP INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE MEMBRO_PERSONALE (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    cognome INTEGER NOT NULL,\n    data_assunzione INTEGER NOT NULL,\n    Type INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE VIDEO_CORSO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    durata INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE PRODOTTO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    costo_unitario INTEGER NOT NULL,\n    marchio INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE TEMPO (\n    data_inizio INTEGER NOT NULL,\n    PRIMARY KEY (data_inizio)\n);\nCREATE TABLE SOCIO (\n    ID INTEGER NOT NULL,\n    nome INTEGER NOT NULL,\n    cognome INTEGER NOT NULL,\n    telefono INTEGER NOT NULL,\n    PRIMARY KEY (ID)\n);\nCREATE TABLE INTERVENTO (\n    MEMBRO_PERSONALE_ID INTEGER NOT NULL,\n    data_ora INTEGER NOT NULL,\n    IMPIANTO_ID INTEGER NOT NULL,\n    PRIMARY KEY (MEMBRO_PERSONALE_ID, data_ora),\n    FOREIGN KEY (MEMBRO_PERSONALE_ID) REFERENCES MEMBRO_PERSONALE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (IMPIANTO_ID) REFERENCES IMPIANTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE RICAMBI (\n    PRODOTTO_ID INTEGER NOT NULL,\n    modello INTEGER NOT NULL,\n    PRIMARY KEY (PRODOTTO_ID),\n    FOREIGN KEY (PRODOTTO_ID) REFERENCES PRODOTTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE CONSUMABILE (\n    PRODOTTO_ID INTEGER NOT NULL,\n    scadenza INTEGER,\n    PRIMARY KEY (PRODOTTO_ID),\n    FOREIGN KEY (PRODOTTO_ID) REFERENCES PRODOTTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE ABBONAMENTO (\n    IMPIANTO_ID INTEGER NOT NULL,\n    ID INTEGER NOT NULL,\n    data_inizio INTEGER NOT NULL,\n    data_fine INTEGER NOT NULL,\n    costo INTEGER NOT NULL,\n    SOCIO_ID INTEGER NOT NULL,\n    PRIMARY KEY (IMPIANTO_ID, ID),\n    FOREIGN KEY (IMPIANTO_ID) REFERENCES IMPIANTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (SOCIO_ID) REFERENCES SOCIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE SESSIONE (\n    SOCIO_ID INTEGER NOT NULL,\n    data_ora_inizio INTEGER NOT NULL,\n    data_ora_fine INTEGER NOT NULL,\n    VIDEO_CORSO_ID INTEGER NOT NULL,\n    PRIMARY KEY (SOCIO_ID, data_ora_inizio),\n    FOREIGN KEY (SOCIO_ID) REFERENCES SOCIO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (VIDEO_CORSO_ID) REFERENCES VIDEO_CORSO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE ELENCO (\n    MEMBRO_PERSONALE_ID INTEGER NOT NULL,\n    VIDEO_CORSO_ID INTEGER NOT NULL,\n    PRIMARY KEY (MEMBRO_PERSONALE_ID, VIDEO_CORSO_ID),\n    FOREIGN KEY (MEMBRO_PERSONALE_ID) REFERENCES MEMBRO_PERSONALE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (VIDEO_CORSO_ID) REFERENCES VIDEO_CORSO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE PRODOTTI_USATI (\n    PRODOTTO_ID INTEGER NOT NULL,\n    INTERVENTO_MEMBRO_PERSONALE_ID INTEGER NOT NULL,\n    INTERVENTO_data_ora INTEGER NOT NULL,\n    qty INTEGER NOT NULL,\n    PRIMARY KEY (PRODOTTO_ID, INTERVENTO_MEMBRO_PERSONALE_ID, INTERVENTO_data_ora),\n    FOREIGN KEY (PRODOTTO_ID) REFERENCES PRODOTTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (INTERVENTO_MEMBRO_PERSONALE_ID, INTERVENTO_data_ora) REFERENCES INTERVENTO (MEMBRO_PERSONALE_ID, data_ora)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE LAVORA (\n    IMPIANTO_ID INTEGER NOT NULL,\n    MEMBRO_PERSONALE_ID INTEGER NOT NULL,\n    TEMPO_data_inizio INTEGER NOT NULL,\n    mansione INTEGER NOT NULL,\n    data_fine INTEGER NOT NULL,\n    PRIMARY KEY (IMPIANTO_ID, MEMBRO_PERSONALE_ID, TEMPO_data_inizio),\n    FOREIGN KEY (IMPIANTO_ID) REFERENCES IMPIANTO (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (MEMBRO_PERSONALE_ID) REFERENCES MEMBRO_PERSONALE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION,\n    FOREIGN KEY (TEMPO_data_inizio) REFERENCES TEMPO (data_inizio)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_SPECIALIZZAZIONI (\n    MEMBRO_PERSONALE_ID INTEGER NOT NULL,\n    SPECIALIZZAZIONI_specializzazioni INTEGER NOT NULL,\n    PRIMARY KEY (MEMBRO_PERSONALE_ID, SPECIALIZZAZIONI_specializzazioni),\n    FOREIGN KEY (MEMBRO_PERSONALE_ID) REFERENCES MEMBRO_PERSONALE (ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);\nCREATE TABLE HAS_CERTIFICAZIONI (\n    CERTIFICAZIONI_certificazioni INTEGER NOT NULL,\n    RICAMBI_PRODOTTO_ID INTEGER NOT NULL,\n    PRIMARY KEY (CERTIFICAZIONI_certificazioni, RICAMBI_PRODOTTO_ID),\n    FOREIGN KEY (RICAMBI_PRODOTTO_ID) REFERENCES RICAMBI (PRODOTTO_ID)\n    ON DELETE NO ACTION\n    ON UPDATE NO ACTION\n);","itemsArray":[{"__type":"Table","_id":114,"_name":"IMPIANTO","_x":-527,"_y":607,"_mag":false},{"__type":"Column","_id":118,"_name":"ID","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":0},{"__type":"Column","_id":119,"_name":"nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":1},{"__type":"Column","_id":120,"_name":"capienza_max","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":2},{"__type":"Column","_id":121,"_name":"indirizzo_via","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":3},{"__type":"Column","_id":122,"_name":"indirizzo_n_civico","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":4},{"__type":"Column","_id":123,"_name":"indirizzo_CAP","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":5},{"__type":"Table","_id":124,"_name":"MEMBRO_PERSONALE","_x":-230,"_y":292,"_mag":false},{"__type":"Column","_id":129,"_na