unique":false,"_nullable":false,"_tableId":225,"_tableIndex":1},"228":{"__type":"ForeignKey","_id":228,"_referencingColumnId":227,"_referencedColumnId":171}},"sqlLinearCode":"<h3>Relational logical schema</h3>IMPIANTO (<u  style=\"text-decoration: underline;\">ID</u>, nome, capienza_max, indirizzo_via, indirizzo_n_civico, indirizzo_CAP)<br><br>\nMEMBRO_PERSONALE (<u  style=\"text-decoration: underline;\">ID</u>, nome, cognome, data_assunzione, Type)<br><br>\nVIDEO_CORSO (<u  style=\"text-decoration: underline;\">ID</u>, nome, durata)<br><br>\nPRODOTTO (<u  style=\"text-decoration: underline;\">ID</u>, nome, costo_unitario, marchio)<br><br>\nTEMPO (<u  style=\"text-decoration: underline;\">data_inizio</u>)<br><br>\nSOCIO (<u  style=\"text-decoration: underline;\">ID</u>, nome, cognome, telefono)<br><br>\nINTERVENTO (<u  style=\"text-decoration: underline;\">MEMBRO_PERSONALE_ID</u>, <u  style=\"text-decoration: underline;\">data_ora</u>, IMPIANTO_ID)<br><br>\nRICAMBI (<u  style=\"text-decoration: underline;\">PRODOTTO_ID</u>, modello)<br><br>\nCONSUMABILE (<u  style=\"text-decoration: underline;\">PRODOTTO_ID</u>, scadenza*)<br><br>\nABBONAMENTO (<u  style=\"text-decoration: underline;\">IMPIANTO_ID</u>, <u  style=\"text-decoration: underline;\">ID</u>, data_inizio, data_fine, costo, SOCIO_ID)<br><br>\nSESSIONE (<u  style=\"text-decoration: underline;\">SOCIO_ID</u>, <u  style=\"text-decoration: underline;\">data_ora_inizio</u>, data_ora_fine, VIDEO_CORSO_ID)<br><br>\nELENCO (<u  style=\"text-decoration: underline;\">MEMBRO_PERSONALE_ID</u>, <u  style=\"text-decoration: underline;\">VIDEO_CORSO_ID</u>)<br><br>\nPRODOTTI_USATI (<u  style=\"text-decoration: underline;\">PRODOTTO_ID</u>, <u  style=\"text-decoration: underline;\">INTERVENTO_MEMBRO_PERSONALE_ID</u>, <u  style=\"text-decoration: underline;\">INTERVENTO_data_ora</u>, qty)<br><br>\nLAVORA (<u  style=\"text-decoration: underline;\">IMPIANTO_ID</u>, <u  style=\"text-decoration: underline;\">MEMBRO_PERSONALE_ID</u>, <u  style=\"text-decoration: underline;\">TEMPO_data_inizio</u>, mansione, data_fine)<br><br>\nHAS_SPECIALIZZAZIONI (<u  style=\"text-decoration: underline;\">MEMBRO_PERSONALE_ID</u>, <u  style=\"text-decoration: underline;\">SPECIALIZZAZIONI_specializzazioni</u>)<br><br>\nHAS_CERTIFICAZIONI (<u  style=\"text-decoration: underline;\">CERTIFICAZIONI_certificazioni</u>, <u  style=\"text-decoration: underline;\">RICAMBI_PRODOTTO_ID</u>)<br><br>\n\n<br><h3>Referential integrity constraints</h3>\n\n\n\n\n\nINTERVENTO (MEMBRO_PERSONALE_ID)  REFERENCES MEMBRO_PERSONALE  (ID)<br><br>INTERVENTO (IMPIANTO_ID)  REFERENCES IMPIANTO  (ID)<br><br>\nRICAMBI (PRODOTTO_ID)  REFERENCES PRODOTTO  (ID)<br><br>\nCONSUMABILE (PRODOTTO_ID)  REFERENCES PRODOTTO  (ID)<br><br>\nABBONAMENTO (IMPIANTO_ID)  REFERENCES IMPIANTO  (ID)<br><br>ABBONAMENTO (SOCIO_ID)  REFERENCES SOCIO  (ID)<br><br>\nSESSIONE (SOCIO_ID)  REFERENCES SOCIO  (ID)<br><br>SESSIONE (VIDEO_CORSO_ID)  REFERENCES VIDEO_CORSO  (ID)<br><br>\nELENCO (MEMBRO_PERSONALE_ID)  REFERENCES MEMBRO_PERSONALE  (ID)<br><br>ELENCO (VIDEO_CORSO_ID)  REFERENCES VIDEO_CORSO  (ID)<br><br>\nPRODOTTI_USATI (PRODOTTO_ID)  REFERENCES PRODOTTO  (ID)<br><br>PRODOTTI_USATI (INTERVENTO_MEMBRO_PERSONALE_ID, INTERVENTO_data_ora)  REFERENCES INTERVENTO  (MEMBRO_PERSONALE_ID, data_ora)<br><br>\nLAVORA (IMPIANTO_ID)  REFERENCES IMPIANTO  (ID)<br><br>LAVORA (MEMBRO_PERSONALE_ID)  REFERENCES MEMBRO_PERSONALE  (ID)<br><br>LAVORA (TEMPO_data_inizio)  REFERENCES TEMPO  (data_inizio)<br><br>\nHAS_SPECIALIZZAZIONI (MEMBRO_PERSONALE_ID)  REFERENCES MEMBRO_PERSONALE  (ID)<br><br>\nHAS_CERTIFICAZIONI (RICAMBI_PRODOTTO_ID)  REFERENCES RICAMBI  (PRODOTTO_ID)<br><br>"},"edited":true,"sceneResetToken":1775642800375,"selectedItemId":null,"oldRenamingValue":"","renamingValue":"","showRenamingInput":false,"showDataTypeOptions":false,"showReorderingMenu":false,"showExportMenu":false},"editorData":null,"showNotesDataMenu":false}