{"_main":{"step":"schemaDesign","restructuringHappened":true,"draftSaved":true,"showMenu":false,"showModal":false,"containerWidth":500,"containerHeight":580,"uid":1},"erDesign":{"model":{"uid":90,"erCode":"/* Entities */\nentity IMPIANTO {\n    ID (id),\n    nome,\n    capienza_max,\n    indirizzo {\n        via,\n        n_civico,\n        CAP\n    }\n}\nentity MEMBRO_PERSONALE {\n    nome,\n    cognome,\n    data_assunzione,\n    ID (id)\n}\nentity MANUTENTORE\nentity ISTRUTTORE {\n    specializzazioni (multi)\n}\nentity VIDEO_CORSO {\n    ID (id),\n    nome,\n    durata\n}\nentity INTERVENTO {\n    data_ora (external)\n}\nentity PRODOTTO {\n    ID (id),\n    nome,\n    costo_unitario,\n    marchio\n}\nentity RICAMBI {\n    modello,\n    certificazioni (multi)\n}\nentity CONSUMABILE {\n    scadenza (optional)\n}\nentity TEMPO {\n    data_inizio (id)\n}\nentity SOCIO {\n    ID (id),\n    nome,\n    cognome,\n    telefono\n}\nentity ABBONAMENTO {\n    ID (external),\n    data_inizio,\n    data_fine,\n    costo\n}\nentity SESSIONE {\n    data_ora_inizio (external),\n    data_ora_fine\n}\n\n/* Relationships */\nrelationship ELENCO (\n    ISTRUTTORE: zero..many,\n    VIDEO_CORSO: one..many\n)\nrelationship SVOLTO_IN (\n    INTERVENTO: one..one,\n    IMPIANTO: zero..many\n)\nrelationship SVOLTO_DA (\n    INTERVENTO: one..one external,\n    MANUTENTORE: zero..many\n)\nrelationship PRODOTTI_USATI (\n    PRODOTTO: zero..many,\n    INTERVENTO: zero..many\n) {\n    qty\n}\nrelationship LAVORA (\n    ISTRUTTORE: zero..many,\n    IMPIANTO: zero..many,\n    TEMPO: one..many\n) {\n    mansione,\n    data_fine\n}\nrelationship PER (\n    IMPIANTO: zero..many,\n    ABBONAMENTO: one..one external\n)\nrelationship SOTTOSCRIVE (\n    ABBONAMENTO: one..one,\n    SOCIO: zero..many\n)\nrelationship VISUALIZZA (\n    SOCIO: zero..many,\n    SESSIONE: one..one external\n)\nrelationship GUARDA (\n    SESSIONE: one..one,\n    VIDEO_CORSO: zero..many\n)\n\n/* Generalizations */\nMEMBRO_PERSONALE <= {\n    ISTRUTTORE,\n    MANUTENTORE\n} (partial, exclusive)\nPRODOTTO <= {\n    RICAMBI,\n    CONSUMABILE\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Entity","_id":1,"_name":"IMPIANTO","_x":-551,"_y":450,"_mag":false},{"__type":"Attribute","_id":2,"_name":"ID","_identifier":true,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":1,"_x":-127,"_y":-64},{"__type":"Attribute","_id":3,"_name":"nome","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":1,"_x":-94,"_y":-102},{"__type":"Attribute","_id":4,"_name":"capienza_max","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":1,"_x":126,"_y":-63},{"__type":"Attribute","_id":5,"_name":"indirizzo","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":1,"_x":9,"_y":-95},{"__type":"Attribute","_id":6,"_name":"via","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":5,"_x":-58,"_y":-31},{"__type":"Attribute","_id":7,"_name":"n_civico","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":5,"_x":5,"_y":-44},{"__type":"Attribute","_id":8,"_name":"CAP","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":5,"_x":63,"_y":-25},{"__type":"Entity","_id":9,"_name":"MEMBRO_PERSONALE","_x":-47,"_y":-63,"_mag":false},{"__type":"Attribute","_id":10,"_name":"nome","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":9,"_x":-201,"_y":0},{"__type":"Attribute","_id":11,"_name":"cognome","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":9,"_x":-202,"_y":-27},{"__type":"Attribute","_id":12,"_name":"data_assunzione","_identifier":false,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":9,"_x":-200,"_y":32},{"__type":"Attribute","_id":13,"_name":"ID","_identifier":true,"_externalIdentifier":false,"_cardinality":"1_1","_parentId":9,"_x":-202,"_y":-54},{"__type":"Entity","_id":14,"