showRenamingRoleInput":false,"showMultivalueAttributeMenu":false,"showCompositeAttributeMenu":false,"showGeneralizationMenu":false,"showExportMenu":false,"showNotes":false},"erTranslation":{"model":{"uid":229,"erCode":"/* Entities */\nentity IMPIANTO {\n    ID (id),\n    nome,\n    capienza_max,\n    indirizzo {\n        via,\n        n_civico,\n        CAP\n    }\n}\nentity MEMBRO_PERSONALE {\n    nome,\n    cognome,\n    data_assunzione,\n    ID (id)\n}\nentity MANUTENTORE\nentity ISTRUTTORE {\n    specializzazioni (multi)\n}\nentity VIDEO_CORSO {\n    ID (id),\n    nome,\n    durata\n}\nentity INTERVENTO {\n    data_ora (external)\n}\nentity PRODOTTO {\n    ID (id),\n    nome,\n    costo_unitario,\n    marchio\n}\nentity RICAMBI {\n    modello,\n    certificazioni (multi)\n}\nentity CONSUMABILE {\n    scadenza (optional)\n}\nentity TEMPO {\n    data_inizio (id)\n}\nentity SOCIO {\n    ID (id),\n    nome,\n    cognome,\n    telefono\n}\nentity ABBONAMENTO {\n    ID (external),\n    data_inizio,\n    data_fine,\n    costo\n}\nentity SESSIONE {\n    data_ora_inizio (external),\n    data_ora_fine\n}\n\n/* Relationships */\nrelationship ELENCO (\n    ISTRUTTORE: zero..many,\n    VIDEO_CORSO: one..many\n)\nrelationship SVOLTO_IN (\n    INTERVENTO: one..one,\n    IMPIANTO: zero..many\n)\nrelationship SVOLTO_DA (\n    INTERVENTO: one..one external,\n    MANUTENTORE: zero..many\n)\nrelationship PRODOTTI_USATI (\n    PRODOTTO: zero..many,\n    INTERVENTO: zero..many\n) {\n    qty\n}\nrelationship LAVORA (\n    ISTRUTTORE: zero..many,\n    IMPIANTO: zero..many,\n    TEMPO: one..many\n) {\n    mansione,\n    data_fine\n}\nrelationship PER (\n    IMPIANTO: zero..many,\n    ABBONAMENTO: one..one external\n)\nrelationship SOTTOSCRIVE (\n    ABBONAMENTO: one..one,\n    SOCIO: zero..many\n)\nrelationship VISUALIZZA (\n    SOCIO: zero..many,\n    SESSIONE: one..one external\n)\nrelationship GUARDA (\n    SESSIONE: one..one,\n    VIDEO_CORSO: zero..many\n)\n\n/* Generalizations */\nMEMBRO_PERSONALE <= {\n    ISTRUTTORE,\n    MANUTENTORE\n} (partial, exclusive)\nPRODOTTO <= {\n    RICAMBI,\n    CONSUMABILE\n} (total, exclusive)","sqlCode":"","itemsArray":[{"__type":"Table","_id":114,"_name":"IMPIANTO","_x":-527,"_y":607,"_mag":false},{"__type":"Column","_id":118,"_name":"ID","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":0},{"__type":"Column","_id":119,"_name":"nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":1},{"__type":"Column","_id":120,"_name":"capienza_max","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":2},{"__type":"Column","_id":121,"_name":"indirizzo_via","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":3},{"__type":"Column","_id":122,"_name":"indirizzo_n_civico","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":4},{"__type":"Column","_id":123,"_name":"indirizzo_CAP","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":114,"_tableIndex":5},{"__type":"Table","_id":124,"_name":"MEMBRO_PERSONALE","_x":-230,"_y":292,"_mag":false},{"__type":"Column","_id":129,"_name":"ID","_type":"integer","_identifier":true,"_unique":false,"_nullable":false,"_tableId":124,"_tableIndex":0},{"__type":"Column","_id":130,"_name":"nome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":124,"_tableIndex":1},{"__type":"Column","_id":131,"_name":"cognome","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":124,"_tableIndex":2},{"__type":"Column","_id":132,"_name":"data_assunzione","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":124,"_tableIndex":3},{"__type":"Column","_id":133,"_name":"Type","_type":"integer","_identifier":false,"_unique":false,"_nullable":false,"_tableId":